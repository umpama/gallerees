<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gallerees.controller.GaleriController"
            prefWidth="950" prefHeight="620"
            style="-fx-background-color: #f4f6f9;">

    <!-- header -->
    <top>
        <VBox alignment="CENTER" spacing="2"
              style="-fx-background-color: linear-gradient(to right, #4568dc, #b06ab3);
                     -fx-padding: 16;">
            <Label text="Manajemen Galeri Visual"
                   style="-fx-text-fill: white; -fx-font-weight: bold;">
                <font><Font size="22"/></font>
            </Label>
            <Label text="Tugas Besar PBO — D3 Sistem Informasi"
                   style="-fx-text-fill: #e0e0e0;">
                <font><Font size="12"/></font>
            </Label>
        </VBox>
    </top>

    <!-- tabel -->
    <center>
        <VBox spacing="8" BorderPane.alignment="CENTER">
            <padding><Insets top="12" right="12" bottom="6" left="12"/></padding>

            <Label text="Daftar Aset Visual" style="-fx-font-weight: bold; -fx-font-size: 14;">
            </Label>

            <TableView fx:id="tabelAset" VBox.vgrow="ALWAYS" prefHeight="250"
                       style="-fx-background-radius: 6; -fx-border-radius: 6;">
                <columns>
                    <TableColumn fx:id="colId"    text="ID"        prefWidth="50"  />
                    <TableColumn fx:id="colNama"  text="Nama Aset" prefWidth="180" />
                    <TableColumn fx:id="colTema"  text="Tema"      prefWidth="140" />
                    <TableColumn fx:id="colJenis" text="Jenis"     prefWidth="120" />
                    <TableColumn fx:id="colPath"  text="Path File" prefWidth="260" />
                </columns>
                <placeholder>
                    <Label text="Belum ada data. Silakan tambahkan aset baru." />
                </placeholder>
            </TableView>
        </VBox>
    </center>

    <!-- Form + Preview -->
    <bottom>
        <HBox spacing="16">
            <padding><Insets top="6" right="12" bottom="12" left="12"/></padding>

            <!-- Form Input -->
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #dcdcdc; -fx-border-radius: 8;
                         -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">

                <Label text="Form Input Aset" style="-fx-font-weight: bold; -fx-font-size: 13;" />

                <GridPane hgap="10" vgap="8">
                    <!-- Nama -->
                    <Label text="Nama Aset"   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtNama" GridPane.rowIndex="0" GridPane.columnIndex="1"
                               promptText="Masukkan nama aset" prefWidth="260"/>

                    <!-- Tema -->
                    <Label text="Tema"         GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTema"  GridPane.rowIndex="1" GridPane.columnIndex="1"
                               promptText="Contoh: Landscape, Portrait"/>

                    <!-- Path File -->
                    <Label text="Path File"         GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <HBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                        <TextField fx:id="txtPathFile" promptText="C:/images/foto.jpg" HBox.hgrow="ALWAYS" prefWidth="200"/>
                        <Button text="Pilih..." onAction="#onBrowsePath" prefWidth="55" style="-fx-cursor: hand; -fx-background-color: #e9ecef; -fx-border-color: #ced4da; -fx-border-radius: 3; -fx-background-radius: 3;"/>
                    </HBox>

                    <!-- Jenis -->
                    <Label text="Jenis"              GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbJenis"        GridPane.rowIndex="3" GridPane.columnIndex="1"
                              prefWidth="260"/>
                </GridPane>

                <!-- Tombol Aksi -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="4"/></padding>
                    <Button fx:id="btnSimpan"    text="Simpan"    onAction="#onSimpan"
                            style="-fx-background-color: #4568dc; -fx-text-fill: white;
                                   -fx-background-radius: 5; -fx-cursor: hand;"
                            prefWidth="90"/>
                    <Button fx:id="btnUbah"      text="Ubah"      onAction="#onUbah"
                            style="-fx-background-color: #f0ad4e; -fx-text-fill: white;
                                   -fx-background-radius: 5; -fx-cursor: hand;"
                            prefWidth="90"/>
                    <Button fx:id="btnHapus"     text="Hapus"     onAction="#onHapus"
                            style="-fx-background-color: #d9534f; -fx-text-fill: white;
                                   -fx-background-radius: 5; -fx-cursor: hand;"
                            prefWidth="90"/>
                    <Button fx:id="btnBersihkan" text="Bersihkan" onAction="#onBersihkan"
                            style="-fx-background-color: #6c757d; -fx-text-fill: white;
                                   -fx-background-radius: 5; -fx-cursor: hand;"
                            prefWidth="90"/>
                </HBox>
            </VBox>

            <!-- Image Preview -->
            <VBox spacing="6" alignment="TOP_CENTER" minWidth="260"
                  style="-fx-background-color: white; -fx-background-radius: 8;
                         -fx-border-color: #dcdcdc; -fx-border-radius: 8;
                         -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);">

                <Label text="Preview Gambar" style="-fx-font-weight: bold; -fx-font-size: 13;" />

                <ImageView fx:id="imgPreview" fitWidth="230" fitHeight="200"
                           preserveRatio="true"
                           style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 8, 0, 0, 3);">
                </ImageView>

                <Label text="Klik baris tabel untuk preview"
                       style="-fx-text-fill: #999; -fx-font-size: 11;"/>
            </VBox>
        </HBox>
    </bottom>

</BorderPane>